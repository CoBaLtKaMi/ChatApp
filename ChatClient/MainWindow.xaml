<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Client" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#f0f0f0" Padding="10" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="ServerIpTextBox" Width="120" Text="127.0.0.1" Margin="0,0,10,0"/>
                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="PortTextBox" Width="60" Text="5000" Margin="0,0,10,0"/>
                <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="UsernameTextBox" Width="120" Margin="0,0,10,0"/>
                <Button x:Name="ConnectButton" Content="Connect" Width="80" Background="#4CAF50" Foreground="White" Click="ConnectButton_Click"/>
                <Button x:Name="DisconnectButton" Content="Disconnect" Width="80" Background="#f44336" Foreground="White" Click="DisconnectButton_Click" IsEnabled="False" Margin="10,0,0,0"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#ddd" BorderThickness="1" Margin="0,0,10,0">
            <ScrollViewer x:Name="MessageScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MessagesItemsControl" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#f5f5f5" Padding="8" Margin="0,2" CornerRadius="5">
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#ddd" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#4CAF50" Padding="10">
                    <TextBlock Text="Online" Foreground="White" FontWeight="Bold"/>
                </Border>
                <ListBox x:Name="UsersListBox" Grid.Row="1" Background="#fafafa" BorderThickness="0" Margin="5"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MessageTextBox" Grid.Column="0" KeyDown="MessageTextBox_KeyDown" IsEnabled="False" Padding="5"/>
                <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="80" Background="#2196F3" Foreground="White" Click="SendButton_Click" IsEnabled="False" Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>