<Window x:Class="ChatServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Server" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#f0f0f0" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Chat Server Control Panel" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="PortTextBox" Width="80" Text="5000" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="StartButton" Content="Start Server" Width="100" 
                            Background="#4CAF50" Foreground="White" Click="StartButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="StopButton" Content="Stop Server" Width="100" 
                            Background="#f44336" Foreground="White" Click="StopButton_Click" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#e8f5e9" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " FontWeight="Bold"/>
                <TextBlock x:Name="StatusTextBlock" Text="Stopped" Foreground="Red"/>
                <TextBlock Text=" | Connected clients: " FontWeight="Bold" Margin="20,0,0,0"/>
                <TextBlock x:Name="ClientsCountTextBlock" Text="0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="#ddd" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="LogListBox" Background="#fafafa" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" 
                                     TextWrapping="Wrap" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="ClearLogButton" Content="Clear Log" Width="100" Click="ClearLogButton_Click"/>
        </StackPanel>
    </Grid>
</Window>